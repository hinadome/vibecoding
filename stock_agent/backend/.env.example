# Server
APP_ENV=dev
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000
# Optional regex fallback for local dev origins (localhost/127.0.0.1 any port)
CORS_ORIGIN_REGEX=^https?://([a-zA-Z0-9\\.\\-]+|\\[::1\\])(:\\d+)?$

# OpenAI-compatible endpoint
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_or_compatible_api_key
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: Tavily web search
TAVILY_API_KEY=

# Optional: Serper web search
SERPER_API_KEY=

# Optional: Exa web search
EXA_API_KEY=

# Optional: SEC/EDGAR primary-source ingestion
# SEC requests should include a descriptive user-agent with contact information.
SEC_USER_AGENT=DeepResearchStockAssistant/0.1 (ops@example.com)
SEC_MAX_FILINGS=4
SEC_REQUEST_RETRIES=2
SEC_RETRY_BACKOFF_MS=400
SEC_TICKER_CACHE_TTL_SEC=21600
SEC_FILING_EXCERPT_CHARS=900

# Optional: Qdrant vector DB
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=stock_research

# Optional: MCP/A2A external integrations (JSON object maps)
# Example:
# MCP_SERVERS_JSON={"market-mcp":{"url":"http://localhost:9001/mcp","bearer_token":"token"}}
# A2A_AGENTS_JSON={"risk-agent":{"url":"http://localhost:9101/invoke","bearer_token":"token"}}
MCP_SERVERS_JSON={}
A2A_AGENTS_JSON={}
OUTBOUND_TIMEOUT_SEC=20
