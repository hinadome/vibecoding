# Search Agent Backend Environment Variables

# The origins that are allowed to make cross-site HTTP requests
CORS_ORIGINS=["*"]
# Data store locations
QDRANT_PATH="./qdrant_data"
CHROMA_PATH="./chroma_data"
# Database selection — swap these to change which is primary / fallback
# Accepted values: "qdrant", "chroma"
PRIMARY_DB="qdrant"
FALLBACK_DB="chroma"
# Embedder Model
EMBEDDER_MODEL="all-MiniLM-L6-v2"
